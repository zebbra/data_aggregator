WAFFLE_ASSET_HOST=http://localhost:4003
ENV_NAME=bench

# DataAggregator.Api.Helpers.grscicoll_api_base_url/0 raises on nil; the
# others would crash on nil concat if a non-stubbed path reaches them.
# Mimic stubs intercept actual calls in bench, so values are placeholders.
GRSCICOLL_API_BASE_URL=https://api.gbif.org/v1/grscicoll
GBIF_SPECIES_API_BASE_URL=https://api.gbif.org/v2
GBIF_API_BASE_URL=https://api.gbif-uat.org/v1
GBIF_BASE_URL=https://www.gbif-uat.org
INFOSPECIES_API_BASE_URL=https://api.infospecies.org/v1

# InfospeciesCenters.get_center_mails! raises on nil (hit by the bench
# seeder and the validate scenario). Never delivered — Swoosh.Adapters.Test.
CENTER_EMAIL_INFOFAUNA=bench@example.com
CENTER_EMAIL_VOGELWARTE=bench@example.com
CENTER_EMAIL_INFOFLORA=bench@example.com
CENTER_EMAIL_SWISSBRYOPHYTES=bench@example.com
CENTER_EMAIL_SWISSLICHENS=bench@example.com
CENTER_EMAIL_SWISSFUNGI=bench@example.com
