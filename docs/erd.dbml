Table record_encoding_results {
  id uuid [pk]
  input jsonb
  output jsonb
  message varchar
  catalog varchar
  state varchar
  inserted_at timestamp
  updated_at timestamp
  record_id uuid
}

Table exports {
  id uuid [pk]
  name varchar
  exported_at timestamp
  started_at timestamp
  finished_at timestamp
  mapping jsonb
  records_query bytea
  exported_count integer
  rows_count integer
  inserted_at timestamp
  updated_at timestamp
  collection_id uuid
  attachment_id uuid
  job_id integer
  state varchar
}

Table imports {
  id uuid [pk]
  columns array
  inserted_at timestamp
  updated_at timestamp
  started_at timestamp
  finished_at timestamp
  rows_count integer
  rows_valid_count integer
  rows_invalid_count integer
  rows_imported_count integer
  collection_id uuid
  attachment_id uuid
  job_id integer
  state varchar
}

Table import_records {
  import_id uuid [pk]
  record_id uuid [pk]
}

Table publications {
  id uuid [pk]
  name varchar
  channel varchar
  published_at timestamp
  started_at timestamp
  finished_at timestamp
  records_query bytea
  published_count integer
  rows_count integer
  inserted_at timestamp
  updated_at timestamp
  collection_id uuid
  attachment_id uuid
  job_id integer
  state varchar
}

