

Table file_attachments {
  id uuid [pk]
  filename varchar
  byte_size integer
  inserted_at timestamp
  updated_at timestamp
}

Table institutions {
  id uuid [pk]
  name varchar
  code varchar
  address varchar
  zip_code varchar
  city varchar
  country varchar
  mail varchar
  tel varchar
  contact_person varchar
  grscicoll_reference varchar
  inserted_at timestamp
  updated_at timestamp
}

Table collections {
  id uuid [pk]
  items_to_digitize integer
  owner varchar
  name varchar
  code varchar
  grscicoll_reference varchar
  description varchar
  import_mapping array
  type varchar
  inserted_at timestamp
  updated_at timestamp
  institution_id uuid
}

