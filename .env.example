# Data Aggregator Environment Configuration
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgres://data_aggregator:your_password@localhost:5432/data_aggregator
# Or configure individual components
POSTGRES_USER=data_aggregator
POSTGRES_PASSWORD=your_password
POSTGRES_DB=data_aggregator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# API Keys
OPEN_CAGE_DATA_API_KEY=your_opencage_api_key_here

# GBIF Configuration
GBIF_INSTALLATION_KEY=your_gbif_installation_key
GBIF_ORGANIZATION_KEY=your_gbif_organization_key
GBIF_USER=your_gbif_username
GBIF_PASSWORD=your_gbif_password

# AWS/S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_DEBUG_REQUESTS=false
AWS_REGION=eu-central-1
# For local MinIO or custom S3-compatible storage
AWS_S3_SCHEME=http
AWS_S3_HOST=localhost
AWS_S3_PORT=9000

# Application Configuration
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret
# Generate with: mix phx.gen.secret

# Mail Configuration
MAILBOX_USERNAME=your_email@example.com
MAILBOX_PASSWORD=your_email_password

# URLs Configuration
BASE_URL=http://localhost:4000
TERMS_URL=https://example.org/terms/
GUIDE_URL=https://example.org/guide/
TUTORIALS_URL=https://example.org/tutorials/

# Deployment Configuration (if needed)
PORT=4000
HOST=localhost
RELEASE_COOKIE=your_release_cookie

# Sentry Configuration (for error tracking)
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Development Tools
# Set to true to enable development tools in development environment
ENABLE_DEV_TOOLS=true