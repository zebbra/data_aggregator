<!DOCTYPE html>
<html lang={to_string(@locale)} class="bg-base-100 [scrollbar-gutter:stable]">
  <head>
    {Application.get_env(:live_debugger, :live_debugger_tags)}

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Data Aggregator to integrate biodiversity data to a darwin core compatible data format."
    />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · DataAggregator">
      {assigns[:page_title] || "Dashboard"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script>
      !function(b,e,t,r){
        b[t]=b[t]||function(...args){(b[t].q=b[t].q||[]).push(args)};
        b[t].l=+new Date;
        var s=e.createElement('script'); s.async=1; s.crossOrigin='anonymous';
        s.src='https://betterstack.net/b.js?t='+r;
        (e.head||e.getElementsByTagName('head')[0]).appendChild(s);
      }(window,document,'betterstack','AUMZxyKMAWnATe6F7rfqDQGY');
      betterstack('init', { environment: '<%= System.get_env("ENV_NAME") %>' });
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-base-100 antialiased">
    {@inner_content}
  </body>
</html>
