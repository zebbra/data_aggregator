#!/bin/bash

set -e

function header {
  echo
  echo "=================================================="
  echo " Running $1 ..."
  echo "=================================================="
  echo
}

header 'Deps Audit'
mix deps.audit

header 'Format'
mix format

header 'Lint'
mix lint

header 'I18n'
mix gettext.extract --merge

header 'Test'
mix test
