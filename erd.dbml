Table records {
  id uuid [pk]
  unique_qualifier varchar
  import_data jsonb
  meta_data jsonb
  inserted_at timestamp
  updated_at timestamp
  collection_id uuid
}

Table record_images {
  id uuid [pk]
  size integer
  inserted_at timestamp
  updated_at timestamp
  attachment_id uuid
  record_id uuid
}

Table collections {
  id uuid [pk]
  name varchar
  code varchar
  description varchar
  mapping jsonb
  inserted_at timestamp
  updated_at timestamp
  institution_id uuid
}

Table import_files {
  id uuid [pk]
  amount_of_rows integer
  inserted_at timestamp
  updated_at timestamp
  collection_id uuid
  attachment_id uuid
}

Table institutions {
  id uuid [pk]
  name varchar
  address varchar
  zip_code varchar
  city varchar
  country varchar
  mail varchar
  tel varchar
  contact_person varchar
  inserted_at timestamp
  updated_at timestamp
}

Table attachments {
  id uuid [pk]
  url varchar
  meta_data jsonb
  inserted_at timestamp
  updated_at timestamp
}

Table attribute_resolving_strategies {
  id uuid [pk]
  do_not_encode boolean
  inserted_at timestamp
  updated_at timestamp
  collection_id uuid
  dwc_attribute_id uuid
  catalog_id uuid
}

Table catalogs {
  id uuid [pk]
  name varchar
  description varchar
  url varchar
  version integer
  inserted_at timestamp
  updated_at timestamp
}

Table dwc_attributes {
  id uuid [pk]
  name varchar
  inserted_at timestamp
  updated_at timestamp
  default_catalog_id uuid
}

Table schema_migrations {
  version integer
  inserted_at timestamp
}

Ref: attachments.id < import_files.attachment_id
Ref: attachments.id < record_images.attachment_id
Ref: catalogs.id < attribute_resolving_strategies.catalog_id
Ref: catalogs.id < dwc_attributes.default_catalog_id
Ref: collections.id < attribute_resolving_strategies.collection_id
Ref: collections.id < import_files.collection_id
Ref: collections.id < records.collection_id
Ref: dwc_attributes.id < attribute_resolving_strategies.dwc_attribute_id
Ref: institutions.id < collections.institution_id
Ref: records.id < record_images.record_id
